# Video Factory — environment

# --- Tenant / project (Spine scoping) ---
VF_TENANT_ID=flipkart                 # one tenant per client; Spine RLS scopes rows by this
VF_PROJECT=video-factory

# --- Generation (aggregator) ---
FAL_KEY=                              # fal.ai — Kling 3.0 Pro (default) + Seedance 2.0 (fallback)
REPLICATE_API_TOKEN=                  # secondary aggregator (failover)

# --- Agents (Google ADK) ---
GOOGLE_API_KEY=                       # Gemini — Prompt-Builder / QC-flagger / Rework agents
ADK_PROVIDER=google                   # google | openai | anthropic  (per-project, like Report Factory)
VF_AGENT_MODEL=gemini-2.0-flash       # model id for the project's agents
# OPENAI_API_KEY=                     # if ADK_PROVIDER=openai
# ANTHROPIC_API_KEY=                  # if ADK_PROVIDER=anthropic

# --- Output spec (resolves the SOW contradiction — see backend/spec.py) ---
VF_SPEC_PRESET=sow_written            # sow_written (960x720, <=10MB, 10-12s) | sample (1080x1920, <=17MB, 13s)

# --- Finishing ---
FFMPEG_BIN=                           # leave blank to auto-resolve; or absolute path to ffmpeg
VF_MUSIC_DIR=assets/music             # non-copyrighted background tracks muxed in finishing
VF_FONT_FILE=                         # watermark/super font; blank = auto (Windows Arial / DejaVu)

# --- Persistence (Phase 2: Postgres on Railway; Phase 1 uses local SQLite) ---
DATABASE_URL=                         # postgresql://... (blank → sqlite:///./var/video_factory.db)

# --- Orchestration (Phase 2) ---
VF_QUEUE_BACKEND=sync                 # sync (default, in-process, Windows-safe) | rq (Redis workers)
# REDIS_URL=redis://localhost:6379/0  # required when VF_QUEUE_BACKEND=rq
VF_COST_CEILING_USD=1.50              # per-job estimated-cost ceiling; over this won't auto-generate
VF_JOB_TIMEOUT_S=1800                 # RQ per-job timeout
VF_SLA_PREMIUM_S=7200                 # enqueue→delivered budget for premium/hero SKUs (2h)
VF_SLA_BASIC_S=21600                  # enqueue→delivered budget for basic SKUs (6h)
# VF_SIMULATE_GEN_FAILURE=            # test hook: e.g. "kling" forces Kling to fail → fallback to Seedance

# --- Delivery (Phase 2) ---
# GOOGLE_DRIVE_FOLDER_ID=             # SOW delivery target
# GDRIVE_SERVICE_ACCOUNT_JSON=

# --- Ops + QC console (Phase 3 UI — scripts/serve.py) ---
VF_API_HOST=127.0.0.1                 # 0.0.0.0 to expose on the network
VF_API_PORT=8310                      # http://localhost:8310
VF_OPEN_BROWSER=1                     # auto-open the console on launch (0 to disable)

# --- Spine connector creds (production; Spine calls this project's API) ---
# SPINE_VF_BASE_URL=http://localhost:8310
# SPINE_VF_EMAIL=
# SPINE_VF_PASSWORD=
