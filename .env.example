# AI Influencer Factory — environment

# --- Tenant / project (row scoping) ---
VF_TENANT_ID=factory                  # scopes characters + posts; one tenant per workspace
VF_PROJECT=influencer-factory

# --- Generation (fal.ai) ---
FAL_KEY=                              # fal.ai key — stills (Nano Banana) + image-to-video (Wan/Kling)
VF_VIDEO_RESOLUTION=480p              # 480p (cheapest) | 720p | 1080p — per-shot video resolution

# --- Prompt refinement (optional, Google ADK / Gemini) ---
VF_USE_LLM=0                          # 1=refine still prompts via Gemini | 0=deterministic prompts
GOOGLE_API_KEY=                       # Gemini key (only when VF_USE_LLM=1)
VF_AGENT_MODEL=gemini-2.0-flash

# --- Output format ---
VF_SPEC_PRESET=reel                   # reel (1080x1920) | square (1080x1080) | landscape (1920x1080)

# --- Identity / visual QC (fal any-llm/vision; reuses FAL_KEY) ---
VF_VLM_QC=1                           # 1=run identity QC on real posts (flag->human) | 0=off
VF_VLM_MODEL=google/gemini-2.5-flash-lite

# --- Finishing (FFmpeg) ---
FFMPEG_BIN=                           # leave blank to auto-resolve; or absolute path to ffmpeg
FFPROBE_BIN=
VF_MUSIC_DIR=assets/music             # non-copyrighted background tracks muxed in finishing
VF_FONT_FILE=                         # caption/super font; blank = auto (Windows Arial / DejaVu)

# --- Persistence (Postgres on Railway in prod; local SQLite by default) ---
DATABASE_URL=                         # postgresql://... (blank -> sqlite:///./var/video_factory.db)

# --- Orchestration ---
VF_QUEUE_BACKEND=sync                 # sync (default, in-process, Windows-safe) | rq (Redis workers)
# REDIS_URL=redis://localhost:6379/0  # required when VF_QUEUE_BACKEND=rq
VF_COST_CEILING_USD=1.50              # per-post estimated-cost ceiling; over this won't auto-generate
VF_SLA_PREMIUM_S=7200                 # create->delivered budget for a premium character (2h)
VF_SLA_BASIC_S=21600                  # create->delivered budget for a basic character (6h)
# VF_SIMULATE_GEN_FAILURE=            # test hook: e.g. "wan-2.5" forces that model to fail

# --- Console (scripts/serve.py) ---
VF_API_HOST=127.0.0.1                 # 0.0.0.0 to expose on the network
VF_API_PORT=8310                      # http://localhost:8310
VF_OPEN_BROWSER=1                     # auto-open the console on launch (0 to disable)
